{
  "name": "bolao-copa-2026",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "build:cloudflare": "cross-env VITE_BASE_PATH=/ VITE_POOL_ID=copa-2026 vite build",
    "pages:dev": "npm run build:cloudflare && wrangler pages dev dist --d1 DB=bolao-copa2026 --persist-to .wrangler/state",
    "deploy:pages": "npm run build:cloudflare && wrangler pages deploy dist",
    "deploy:results-worker": "wrangler deploy --config workers/live-results/wrangler.jsonc",
    "deploy:cloudflare": "npm run deploy:pages && npm run deploy:results-worker",
    "preview": "vite preview --host 127.0.0.1",
    "test": "node --test"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "cross-env": "^10.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "wrangler": "^4.54.0"
  }
}
